import { log } from 'ding:std'

struct Vec2 {
  x: number
  y: number

  const length = (self) => {
    return self.x * self.x + self.y * self.y
  }

  const add = (self, other) => {
    return Vec2 { x: self.x + other.x, y: self.y + other.y }
  }
}

const a = Vec2 { x: 3, y: 4 }
const b = Vec2 { x: 1, y: 2 }

log(`a.length = ${a.length()}`)

const c = a.add(b)
log(`c = Vec2 { x: ${c.x}, y: ${c.y} }`)
