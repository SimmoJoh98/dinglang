{
  "name": "dinglang",
  "version": "0.1.0",
  "description": "The Ding programming language",
  "type": "module",
  "bin": {
    "ding": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "ding": "node --loader ts-node/esm src/cli/index.ts"
  },
  "keywords": ["programming-language", "compiler", "ding", "dinglang"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "ts-node": "^10.9.0",
    "@types/node": "^22.0.0"
  }
}
